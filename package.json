{
  "name": "web-search-mcp-server",
  "version": "0.7.1",
  "description": "A simple, locally hosted Web Search MCP server for use with Local LLMs (Refactored and Enhanced)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "web-search-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && echo '✅ TypeScript compilation complete: dist/index.js'",
    "dev": "tsx watch src/index.ts",
    "start": "node ./dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write ."
  },
  "keywords": [
    "mcp",
    "web-search",
    "ai",
    "llm"
  ],
  "author": "Mark Russell (Original), Olly Johnston (Enhanced Version)",
  "repository": {
    "type": "git",
    "url": "https://github.com/OllyJohnston/web-search-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/OllyJohnston/web-search-mcp/issues"
  },
  "homepage": "https://github.com/OllyJohnston/web-search-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.0",
    "axios": "^1.6.8",
    "cheerio": "^1.0.0-rc.12",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "p-limit": "^6.2.0",
    "p-retry": "^6.2.1",
    "playwright": "^1.48.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/cheerio": "^1.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "esbuild": "^0.25.5",
    "eslint": "^9.30.1",
    "prettier": "^3.2.5",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5"
  }
}
